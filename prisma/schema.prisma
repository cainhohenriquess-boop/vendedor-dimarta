generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SELLER
}

enum ProductAudience {
  ADULTO
  CRIANCA
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  passwordHash    String
  role            UserRole  @default(SELLER)
  isActive        Boolean   @default(true)
  createdProducts Product[] @relation("ProductCreatedBy")
  updatedProducts Product[] @relation("ProductUpdatedBy")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([name])
}

model Brand {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([name])
}

model Product {
  id               String          @id @default(cuid())
  audience         ProductAudience
  model            String
  shortDescription String
  color            String
  currentPrice     Decimal         @db.Decimal(10, 2)
  promotionalPrice Decimal?        @db.Decimal(10, 2)
  internalCode     String          @unique
  imageUrl         String
  searchDocument   String
  totalStock       Int             @default(0)
  status           ProductStatus   @default(ACTIVE)
  categoryId       String
  brandId          String
  createdById      String?
  updatedById      String?
  category         Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brand            Brand           @relation(fields: [brandId], references: [id], onDelete: Restrict)
  createdBy        User?           @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy        User?           @relation("ProductUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  sizes            ProductSize[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([status, updatedAt])
  @@index([audience])
  @@index([categoryId])
  @@index([brandId])
  @@index([color])
  @@index([model])
  @@index([totalStock])
}

model ProductSize {
  id        String   @id @default(cuid())
  productId String
  size      Int
  stock     Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, size])
  @@index([size])
  @@index([stock])
}
